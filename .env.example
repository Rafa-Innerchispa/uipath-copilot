# Swarm-OS PC Doctor — archivo .env del SERVIDOR 192.168.1.4 (ralphi-ia-ver-10)
# 127.0.0.1 aquí = la misma máquina del servidor (correcto). Desde Windows usa 192.168.1.4
# Ver docs/ACCESO_RED.md
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB=pcdoctor_swarm

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=neural-chat:7b

API_HOST=0.0.0.0
API_PORT=8100

# Webhook n8n para correo / WhatsApp (opcional)
N8N_WEBHOOK_URL=

# Evolution API — alertas WhatsApp al celular
EVOLUTION_BASE_URL=http://127.0.0.1:8082
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=RalphiIA-pcdoctor

# Datos compartidos (fuera del repo — todos los proyectos)
RALPHI_DATA_ROOT=/home/rlopez/data
NOTION_EXPORT_DIR=/home/rlopez/data/notion_export
GDRIVE_SYNC_DIR=/home/rlopez/data/gdrive_sync

# Media operativa SwarmOS (puede symlink a RALPHI_DATA_ROOT/media)
MEDIA_DIR=/home/rlopez/data/media
EXPORTS_DIR=/home/rlopez/projects/innerspark-swarm-os-cursor-local/data/exports

# API RUC (Intuito/Deuna) — usa TUS credenciales, no las del manual público
RUC_API_USER=
RUC_API_PASS=
RUC_API_TOKEN_URL=https://consulta-ruc-token.azurewebsites.net/v1/deuna/creacion-token
RUC_API_LOOKUP_URL=https://consulta-ruc.azurewebsites.net/api/ruc

# Whisper local (docker whisper-service)
WHISPER_URL=http://127.0.0.1:9001

# Visión para fotos de campo
OLLAMA_VISION_MODEL=llava:7b

# Hackathon Devpost
GEMINI_API_KEY=
NGROK_AUTHTOKEN=
HACKATHON_UI_ROOT=/home/rlopez/projects/swarm-os-google_ai_studio

# Hackathon Band of Agents (BOA26) — ver hackathon_band/.env.example
BAND_API_KEY=
BAND_REST_URL=https://app.band.ai
BAND_AGENT_ID_ROUTER=
BAND_AGENT_ID_MEMORY=
BAND_AGENT_ID_ANALYST=
BAND_AGENT_ID_DOCUMENTATION=
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=deepseek/deepseek-r1
HACKATHON_BAND_PORT=5190
HACKATHON_API_PORT=8200
HACKATHON_API_HOST=0.0.0.0
RALPHI_DATA_DOCS=/home/rlopez/data/docs

# WhatsApp alerta al terminar pipeline hackathon (misma Evolution que InnerOS)
# Formato: solo dígitos con código país, ej. 593991234567
HACKATHON_WHATSAPP_TO=
HACKATHON_EMAIL_TO=

# --- uipath-copilot (Maestro Case, puerto 8097) ---
UIPATH_COPILOT_PORT=8097
UIPATH_COPILOT_PUBLIC_URL=http://192.168.1.4:8097
UIPATH_BASE_URL=
UIPATH_CLIENT_ID=
# App Secret: usar .uipath_secret (gitignored) si contiene # $ ^ @
UIPATH_CLIENT_SECRET_FILE=.uipath_secret
UIPATH_CLIENT_SECRET=
UIPATH_ORG_UNIT_ID=
UIPATH_SCOPE=OR.Administration OR.Execution OR.Monitoring
UIPATH_OPERATOR_WHATSAPP=
OLLAMA_MODEL_ANALYSIS=qwen2.5:14b-instruct-q4_K_M
OLLAMA_MODEL_CODER=qwen2.5-coder:7b
AGENTS_POOL_ROOT=/home/rlopez/inneros_core/agents_pool
